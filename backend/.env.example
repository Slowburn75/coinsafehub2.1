# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DATABASE_URL=postgresql://coinsafe:coinsafe@localhost:5432/coinsafehub?schema=public

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email — Resend (resend.com)
# Get your API key at https://resend.com/api-keys
# Leave empty in dev — OTPs logged to console, retrievable via /api/auth/dev/otp
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=CoinSafeHub <noreply@coinsafehub.com>

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000

# Deposit Addresses (fallback if DB empty)
DEPOSIT_ADDRESS_BTC=
DEPOSIT_ADDRESS_ETH=
DEPOSIT_ADDRESS_USDT=
